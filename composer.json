{
    "name": "jackardios/elastic-query-wizard",
    "description": "Laravel Elastic Query Wizard",
    "keywords": [
        "jackardios",
        "scout-query-wizard",
        "laravel-elastic-query-wizard",
        "elastic-query-builder",
        "laravel-query-builder",
        "laravel",
        "scout",
        "elastic",
        "elasticsearch",
        "query",
        "wizard",
        "builder",
        "json",
        "api",
        "json api",
        "query builder",
        "filtering",
        "sorting",
        "search"
    ],
    "homepage": "https://github.com/jackardios/elastic-query-wizard",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/jackardios/elastic-query-wizard/issues",
        "source": "https://github.com/jackardios/elastic-query-wizard"
    },
    "authors": [
        {
            "name": "Salavat Salakhutdinov",
            "email": "salavat.salahutdinov@gmail.com",
            "homepage": "https://github.com/jackardios"
        }
    ],
    "require": {
        "php": "^8.1",
        "jackardios/es-scout-driver": "dev-main",
        "jackardios/laravel-query-wizard": "dev-master",
        "laravel/framework": "^v10.0 || ^v11.0 || ^v12.0"
    },
    "require-dev": {
        "ext-json": "*",
        "babenkoivan/elastic-migrations": "^3.4 || ^4.0",
        "friendsofphp/php-cs-fixer": "^3.14",
        "jackardios/laravel-eloquent-spatial": "^4.0",
        "laravel/scout": "^v10.8.0",
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0",
        "phpstan/phpstan": "^1.10 || ^2.0",
        "phpunit/phpunit": "^10.5 || ^11.0",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "Jackardios\\ElasticQueryWizard\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jackardios\\ElasticQueryWizard\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "test:feature": "phpunit --testsuite=Feature",
        "analyse": "phpstan analyse --memory-limit=512M",
        "format-check": "php-cs-fixer fix --dry-run --diff",
        "format": "php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
